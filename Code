import matplotlib.pyplot as plt   # Librería para graficar
import numpy as np                # Librería para manejar listas de números

# Función que evalúa el polinomio
def evaluar_polinomio(coeficientes, x):
    """
    coeficientes: lista con los coeficientes del polinomio
    x: valor en el que se evalúa
    """
    resultado = 0
    grado = len(coeficientes) - 1   # El grado es el tamaño de la lista - 1
    for i in range(len(coeficientes)):
        # coeficientes[i] * x^(grado - i)
        resultado += coeficientes[i] * (x ** (grado - i))
    return resultado

# Función que grafica el polinomio
def graficar_polinomio(coeficientes):
    # Creamos un rango de valores de x (de -10 a 10 con pasos pequeños)
    x = np.linspace(-10, 10, 400)
    # Calculamos f(x) para cada valor de x
    y = [evaluar_polinomio(coeficientes, xi) for xi in x]

    # Dibujamos la gráfica
    plt.plot(x, y, label="Polinomio")
    plt.axhline(0, color='black')  # Línea horizontal en y=0
    plt.axvline(0, color='black')  # Línea vertical en x=0
    plt.legend()
    plt.show()

# Ejemplo: polinomio x^4 + x^3 + x^2 + x + 1
coeficientes = [1, 1, 1, 1, 1]
graficar_polinomio(coeficientes)

# Otro ejemplo: polinomio x^2
coeficientes2 = [1, 0, 0]  # Representa x^2 + 0x + 0
graficar_polinomio(coeficientes2)
